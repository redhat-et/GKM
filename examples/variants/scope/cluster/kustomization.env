apiVersion: kustomize.config.k8s.io/v1alpha1
kind: Component

patches:
- target:
    kind: ClusterGKMCache
    name: gkm-test-obj
  patch: |-
    # Overwrite the OCI Image in the ClusterGKMCache with the CUDA/ROCm and V2/V3 tag. Whole image, not just tag overwritten
    - op: replace
      path: /spec/image
      value: OCI_IMAGE

    # Add Cosign Version Label to ClusterGKMCache
    - op: add
      path: /metadata/labels
      value: {}
    - op: add
      path: /metadata/labels/gkm.io~1signature-format
      value: COSIGN_VERSION_LABEL

    # Overwrite the namespaces to the `spec.workloadNamespaces` slice in the ClusterGKMCache
    - op: replace
      path: /spec/workloadNamespaces/0
      value: NAMESPACE_1
    - op: replace
      path: /spec/workloadNamespaces/1
      value: NAMESPACE_2

POD_TEMPLATE_ADD_GKMCACHE

ACCESS_ROX_ACCESS_MODE
