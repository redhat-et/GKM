apiVersion: kustomize.config.k8s.io/v1alpha1
kind: Component

patches:
- target:
    kind: GKMCache
    name: gkm-test-obj
  patch: |-
    # Overwrite the Namespace in the GKMCache
    - op: replace
      path: /metadata/namespace
      value: NAMESPACE_1

    # Overwrite the OCI Image in the GKMCache with the CUDA/ROCm and V2/V3 tag. Whole image, not just tag overwritten
    - op: replace
      path: /spec/image
      value: OCI_IMAGE

    # Add Cosign Version Label to GKMCache
    - op: add
      path: /metadata/labels
      value: {}
    - op: add
      path: /metadata/labels/gkm.io~1signature-format
      value: COSIGN_VERSION_LABEL

POD_TEMPLATE_ADD_GKMCACHE

ACCESS_ROX_ACCESS_MODE
